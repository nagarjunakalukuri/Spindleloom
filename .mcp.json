{
  "mcpServers": {
    "spindleloom": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "mcp[cli]",
        "python",
        "${CLAUDE_PROJECT_DIR}/hooks/mcp_server.py"
      ],
      "env": {
        "SPINDLELOOM_SPEC_ROOT": "${CLAUDE_PROJECT_DIR}",
        "SPINDLELOOM_WRITABLE": "",
        "SPINDLELOOM_SEMANTIC": ""
      }
    }
  }
}
