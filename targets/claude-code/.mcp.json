{
  "mcpServers": {
    "wheelwright": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "mcp[cli]",
        "python",
        "${CLAUDE_PROJECT_DIR}/mcp/mcp_server.py"
      ],
      "env": {
        "WHEELWRIGHT_SPEC_ROOT": "${CLAUDE_PROJECT_DIR}"
      }
    }
  }
}
