{
  "mcpServers": {
    "spindleloom": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "mcp[cli]",
        "python",
        "${CLAUDE_PLUGIN_ROOT}/mcp/mcp_server.py"
      ],
      "env": {
        "SPINDLELOOM_SPEC_ROOT": "${CLAUDE_PROJECT_DIR}"
      }
    }
  }
}
